generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Journal {
  id              String    @id @default(cuid())
  authorName      String
  title           String
  content         String
  createdAt       DateTime  @default(now())
  durationSeconds Int?
  topicId         String?
  reviews         Review[]
  topic           Topic?    @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([topicId])
}

model Topic {
  id           String    @id @default(cuid())
  title        String
  titleId      String?
  description  String?
  scheduledFor DateTime  @db.Date
  featuredFor  DateTime? @db.Date
  createdAt    DateTime  @default(now())
  journals     Journal[]

  @@index([scheduledFor])
  @@index([featuredFor])
}

model Review {
  id         String   @id @default(cuid())
  journalId  String
  authorName String
  comment    String
  createdAt  DateTime @default(now())
  journal    Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@index([journalId])
}
